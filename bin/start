#!/usr/bin/env bash
# Exit on error
set -o errexit

# Calculate script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Calculate the process file to run
PROCESS_FILE="Procfile.${RAILS_ENV}"

GOREMAN_EXEC="$(brew --prefix goreman)/bin/goreman"

"$SCRIPT_DIR/build" &&\
  "$SCRIPT_DIR/pre-deploy" &&\
    "$GOREMAN_EXEC" -f "$PROCESS_FILE" start
