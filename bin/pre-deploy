#!/usr/bin/env bash
# Exit on error
set -o errexit

# Setup package dependencies
yarn install --frozen-lockfile

# Install gems
bundle install

# Build css
yarn build:css

# Pre-build app assets
yarn build:assets

# Build frontend
yarn build

## Run asset precompilation and cleanup
#bundle exec rails tailwindcss:build
##bundle exec rails assets:precompile
# TODO: Look into cleaning up old assets
#bundle exec rails assets:clean

# Run database migrations (only on free tier)
bundle exec rails db:migrate

# Apply data migrations
bundle exec rails data:migrate
