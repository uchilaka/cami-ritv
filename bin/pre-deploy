#!/usr/bin/env bash
# Exit on error
set -o errexit

# Calculate script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Decrypt secrets
"$SCRIPT_DIR/unlock-repo"

# Link credential key file
"$SCRIPT_DIR/link-key-file"

# Run database migrations (only on free tier)
bundle exec rake db:migrate

# Apply data migrations
bundle exec rake data:migrate
