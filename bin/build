#!/usr/bin/env bash
# Exit on error
set -o errexit

# Calculate script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Decrypt secrets
"$SCRIPT_DIR/unlock-repo"

# Setup package dependencies
yarn install --immutable

# Install gems
bundle install

# Build css
yarn build:css

# Pre-build app assets
yarn build:assets

# Build frontend
yarn build
