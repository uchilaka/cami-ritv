#!/usr/bin/env bash
# Exit on error
set -o errexit

# Calculate script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Calculate the process file to run
PROCESS_FILE="Procfile.${RAILS_ENV}"

# Run pre-deployment tasks
"$SCRIPT_DIR/pre-deploy"

# Start the processes for the Rails application
/opt/homebrew/bin/goreman -f "$PROCESS_FILE" start
