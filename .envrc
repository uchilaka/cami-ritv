#!/usr/bin/env zsh

set -e
# TODO: Explore templatizing this file for use across multiple environments... or better yet, these templates
# are getting pretty close to the point where they should be moved into a shared library or simplified in a
# way that they can be useful for dev environment setup but otherwise transparent in favor of environment-specific
# configuration files that are loaded by this file. For example, we could have .envrc load .env.lab.local and
# .env.staging.local, etc. and then we can have environment-specific configuration in those files instead of this one.

# TODO: Refactor to retrieve value from .tool-versions file
export NODENV_VERSION=22.14.0

# TODO: Deprecate the use of Direnv in Staging+ environments
export PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# Precedence should match this chart: https://github.com/bkeepers/dotenv?tab=readme-ov-file#customizing-rails
env_files=(
  "${PROJECT_ROOT}/.env"
  "${PROJECT_ROOT}/.env.local"
  "${PROJECT_ROOT}/.env.${RAILS_ENV}"
  "${PROJECT_ROOT}/.env.${RAILS_ENV}.local"
)

for env_file in "${env_files[@]}"; do
  if [[ -f "$env_file" ]]; then
    printf " ⚙️ $(basename "$env_file") "
    source "$env_file"
  fi
done

: "${RAILS_ENV:?RAILS_ENV is not set. Please set RAILS_ENV to the appropriate environment (e.g., development, staging, production).}"
: "${NODE_ENV:?NODE_ENV is not set. Please set NODE_ENV to the appropriate environment (e.g., development, staging, production).}"
: "${CONTAINER_REGISTRY_HOST:?CONTAINER_REGISTRY_HOST is not set. Please set CONTAINER_REGISTRY_HOST to the appropriate container registry host (e.g., registry.fly.io).}"
: "${CONTAINER_NAME_PREFIX:?CONTAINER_NAME_PREFIX is not set. Please set CONTAINER_NAME_PREFIX to the appropriate container name prefix (e.g., cami).}"

# Merging compose files: https://docs.docker.com/compose/how-tos/multiple-compose-files/merge/#how-to-merge-multiple-compose-files
export COMPOSE_PATH_SEPARATOR=":" # On Windows, this should be ";"
# IMPORTANT: The order of the compose files matters. The latter files
# will override the previous ones. For example, compose.override.yml
# should be able to override compose.${NODE_ENV}.yml, and the beta
# postgres compose should be able to override both if needed.
compose_files=(
  "${PROJECT_ROOT}/compose.yml"
  "${PROJECT_ROOT}/docker-compose.yml"
  #"${PROJECT_ROOT}/compose.${RAILS_ENV}.yml"
  #"${PROJECT_ROOT}/docker-compose.${RAILS_ENV}.yml"
  "${PROJECT_ROOT}/compose.override.yml"
  "${PROJECT_ROOT}/docker-compose.override.yml"
)
COMPOSE_FILE=""
for compose_file in "${compose_files[@]}"; do
  if [[ -f "$compose_file" ]]; then
    printf " 🐳 Adding $(basename "$compose_file") to COMPOSE_FILE "
    export COMPOSE_FILE="${COMPOSE_FILE:+$COMPOSE_FILE$COMPOSE_PATH_SEPARATOR}$compose_file"
  else
    printf " ⚠️ Compose file not found: $compose_file. Skipping. "
  fi
done

# TODO: Refactor to have the ./config/dotenvs/.env.<environment>.erb files be the
# source of truth for environment variables and then have this file load those files
# instead of having environment variables defined in multiple places. This would also
# allow us to templatize the .env files and use them across multiple environments
# without having to duplicate environment variable definitions across multiple .env files.

# Attempt to set GITCRYPT_KEY_BASE64 if GITCRYPT_KEY_FILE is set and the file exists
export GITCRYPT_KEY_FILE="${GITCRYPT_KEY_FILE:-config/credentials/git-crypt.key}"
KEY_SRC_FILE="${PROJECT_ROOT}/${GITCRYPT_KEY_FILE}"
if [[ -f "$KEY_SRC_FILE" ]]; then
  printf " 🛠️ Setting \$GITCRYPT_KEY_BASE64 from $GITCRYPT_KEY_FILE "
  export GITCRYPT_KEY_BASE64=$(cat "$KEY_SRC_FILE" | base64)
else
  printf " ⚠️ \$GITCRYPT_KEY_FILE is not found @ $KEY_SRC_FILE. Skipping setting \$GITCRYPT_KEY_BASE64 "
fi

# Knapsack Pro configuration for parallel test execution
export KNAPSACK_PRO_CI_NODE_BUILD_ID=$(date -u +"%Y-%m-%dT%H:%M:%S%z")
export KNAPSACK_PRO_COMMIT_HASH=$(git rev-parse HEAD)
export KNAPSACK_PRO_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Fly.io application name
export FLY_APP_NAME_PREFIX="cami-${RAILS_ENV}"
