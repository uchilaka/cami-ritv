<%= shared_header %>
# Was 1 for local debugging
export RAILS_QUEUE_THREADS=2
export RAILS_MIN_THREADS=3
export RAILS_MAX_THREADS=5

# TODO: Testing between 0 and 2 while observing +[NSCharacterSet initialize] crashing issues on local
export WEB_CONCURRENCY=0

# On-metal database credentials (mise managed service)
#export APP_DATABASE_USER="$USER"
#export APP_DATABASE_PASSWORD=""
#export APP_DATABASE_PORT=5432

<%= build_template_body %>

# Ensure that docker image builds show the full output instead of a progress bar,
# which can be helpful for debuggingg issues with docker builds
export BUILDKIT_PROGRESS=plain

# TODO: See https://github.com/railsjazz/rails_live_reload/pull/42
export RAILS_LIVE_RELOAD_ENABLED=yes

export HOMEBREW_BUNDLE_FILE="<%= Rails.root.join('Brewfile.dev').to_s %>"
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
export DISABLE_SPRING=true
export HOSTNAME=accounts.larcity.ngrok.dev

# Email testing
export LAUNCHY_APPLICATION=chrome

# Email controls - the following are the defaults in AppUtils
export SEND_EMAILS_ENABLED=no
#export LETTER_OPENER_ENABLED=yes
export MAILHOG_ENABLED=yes

#export NGROK_PROFILE_CONFIG_PATH="$(realpath ~/.ngrok2/ngrok.yml)"
# This should be the root path for the project i.e. Rails.root
export PROJECT_ROOT="<%= Rails.root.to_s %>"

export LAN_SUBNET_MASK="0.0.0.0/0"

export DATABASE_ROOT_DIR="<%= Rails.root.join('db', detected_environment, 'postgres').to_s %>"

# ETL
export UPSERT_INVOICE_BATCH_LIMIT=1000

# Error testing
export ENV_CONSIDER_ALL_REQUESTS_LOCAL=no

# Other debuggers(?) - re-consolidate some of these variables
export ENV_DEBUG_ASSETS=yes

# Debugging
export APP_DEBUG_MODE=no
