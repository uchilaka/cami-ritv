features:
  - buildpack-stack=ubuntu-22
ingress:
  rules:
    - component:
        name: cami-production-web
      match:
        authority:
          exact: ""
        path:
          prefix: /
name: larcity-production-app
region: nyc
services:
  - build_command: ./bin/build
    environment_slug: ruby-on-rails
    envs:
    - key: DATABASE_URL
      scope: RUN_TIME
      value: ${db-postgresql-production-larcity.DATABASE_URL}
    github:
      branch: releases/production
      deploy_on_push: true
      repo: uchilaka/cami-ritv
    http_port: 16006
    instance_count: 1
    instance_size_slug: apps-s-1vcpu-0.5gb
    name: cami-production-web
    run_command: ./bin/pre-deploy && rails server -p $PORT
    source_dir: /
vpc:
  id: <%= Rails.application.credentials.digitalocean.vpc_id! %>
workers:
  - build_command: ./bin/worker-build
    environment_slug: ruby-on-rails
    envs:
    - key: DATABASE_URL
      scope: RUN_TIME
      value: ${db-postgresql-production-larcity.DATABASE_URL}
    github:
      branch: releases/production
      deploy_on_push: true
      repo: uchilaka/cami-ritv
    instance_count: 1
    instance_size_slug: apps-s-1vcpu-0.5gb
    name: cami-production-worker
    run_command: ./bin/pre-deploy && rails solid_queue:start
    source_dir: /
